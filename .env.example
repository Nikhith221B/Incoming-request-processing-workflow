# LLM provider: auto | gemini | ollama | fallback
# auto = Gemini when GEMINI_API_KEY is set, otherwise local Ollama
LLM_PROVIDER=auto

# Optional Google Gemini (cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional local Ollama (open-source)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
